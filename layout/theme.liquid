<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#0d2e0d">
  <title>{{ page_title }}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}{% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}</title>
  {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}
  <link rel="canonical" href="{{ canonical_url }}">
  {% if settings.favicon %}<link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">{% endif %}
  {{ content_for_header }}
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-size: 16px; -webkit-text-size-adjust: 100%; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      color: #1a1a1a; background: #fff; line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; height: auto; display: block; }
    button { font-family: inherit; cursor: pointer; }

    /* Skip link */
    .skip-link {
      position: absolute; left: -9999px; top: auto; width: 1px; height: 1px; overflow: hidden;
    }
    .skip-link:focus {
      left: 16px; top: 16px; width: auto; height: auto; padding: 8px 16px;
      background: #0d2e0d; color: #fff; border-radius: 6px; z-index: 9999; font-size: 0.9rem;
    }

    /* Cart drawer overlay */
    #lg-cart-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,0.5); z-index: 900;
    }
    #lg-cart-drawer {
      position: fixed; top: 0; right: -420px; width: 100%; max-width: 420px;
      height: 100%; background: #fff; z-index: 901;
      transition: right 0.3s ease; display: flex; flex-direction: column;
      box-shadow: -4px 0 24px rgba(0,0,0,0.12);
    }
    #lg-cart-drawer.open { right: 0; }
    .lg-cart-head {
      display: flex; align-items: center; justify-content: space-between;
      padding: 20px 24px; border-bottom: 1px solid #e8e8e8;
    }
    .lg-cart-head h2 { font-size: 1rem; font-weight: 700; }
    .lg-cart-close { background: none; border: none; font-size: 1.4rem; color: #1a1a1a; padding: 4px; }
    .lg-cart-body { flex: 1; overflow-y: auto; padding: 24px; }
    .lg-cart-empty { text-align: center; color: #888; padding: 48px 0; font-size: 0.9rem; }
    .lg-cart-items { display: flex; flex-direction: column; gap: 16px; }
    .lg-cart-item { display: grid; grid-template-columns: 72px 1fr auto; gap: 12px; align-items: start; }
    .lg-cart-item img { width: 72px; height: 72px; object-fit: cover; border-radius: 8px; background: #f5f5f5; }
    .lg-cart-item-title { font-size: 0.88rem; font-weight: 600; color: #1a1a1a; margin-bottom: 4px; }
    .lg-cart-item-var { font-size: 0.78rem; color: #888; }
    .lg-cart-item-price { font-size: 0.88rem; font-weight: 700; color: #0d2e0d; white-space: nowrap; }
    .lg-cart-footer { padding: 20px 24px; border-top: 1px solid #e8e8e8; }
    .lg-cart-subtotal { display: flex; justify-content: space-between; font-size: 0.95rem; font-weight: 700; margin-bottom: 16px; }
    .lg-cart-checkout-btn {
      display: block; width: 100%; padding: 16px; border: none; border-radius: 10px;
      background: #0d2e0d; color: #fff; font-size: 1rem; font-weight: 700;
      text-align: center; cursor: pointer; transition: background 0.2s;
    }
    .lg-cart-checkout-btn:hover { background: #1a4a1a; }
  </style>
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>

  {%- sections 'header' -%}

  <!-- Cart drawer -->
  <div id="lg-cart-overlay"></div>
  <div id="lg-cart-drawer" role="dialog" aria-label="Shopping cart">
    <div class="lg-cart-head">
      <h2>Your Cart (<span id="lg-cart-count-drawer">0</span>)</h2>
      <button class="lg-cart-close" id="lg-cart-close-btn" aria-label="Close cart">×</button>
    </div>
    <div class="lg-cart-body" id="lg-cart-body">
      <p class="lg-cart-empty">Your cart is empty</p>
    </div>
    <div class="lg-cart-footer">
      <div class="lg-cart-subtotal">
        <span>Subtotal</span>
        <span id="lg-cart-subtotal">$0.00</span>
      </div>
      <a href="/checkout" class="lg-cart-checkout-btn" id="lg-cart-checkout-link">Checkout</a>
    </div>
  </div>

  <main id="main-content">
    {{ content_for_layout }}
  </main>

  <script>
  // ── Cart drawer ──────────────────────────────────────────────────
  (function () {
    var overlay   = document.getElementById('lg-cart-overlay');
    var drawer    = document.getElementById('lg-cart-drawer');
    var closeBtn  = document.getElementById('lg-cart-close-btn');
    var cartBody  = document.getElementById('lg-cart-body');
    var subtotalEl = document.getElementById('lg-cart-subtotal');
    var countDrawer = document.getElementById('lg-cart-count-drawer');

    function fmt(cents) { return '$' + (cents / 100).toFixed(2); }

    function renderCart(cart) {
      var count = cart.item_count || 0;
      countDrawer.textContent = count;
      // Update all header cart count badges
      document.querySelectorAll('.lg-header-cart-count').forEach(function(el){ el.textContent = count; });
      subtotalEl.textContent = fmt(cart.total_price || 0);
      if (!count) { cartBody.innerHTML = '<p class="lg-cart-empty">Your cart is empty</p>'; return; }
      var html = '<div class="lg-cart-items">';
      (cart.items || []).forEach(function(item) {
        var imgSrc = item.featured_image && item.featured_image.url ? item.featured_image.url : '';
        html += '<div class="lg-cart-item">';
        if (imgSrc) html += '<img src="' + imgSrc + '" alt="' + item.title + '" />';
        else html += '<div style="width:72px;height:72px;background:#f5f5f5;border-radius:8px"></div>';
        html += '<div><div class="lg-cart-item-title">' + item.product_title + '</div>';
        if (item.variant_title && item.variant_title !== 'Default Title') {
          html += '<div class="lg-cart-item-var">' + item.variant_title + '</div>';
        }
        html += '<div class="lg-cart-item-var">Qty: ' + item.quantity + '</div></div>';
        html += '<div class="lg-cart-item-price">' + fmt(item.final_line_price) + '</div>';
        html += '</div>';
      });
      html += '</div>';
      cartBody.innerHTML = html;
    }

    function openCart() {
      fetch('/cart.js').then(function(r){ return r.json(); }).then(function(cart){
        renderCart(cart);
        drawer.classList.add('open');
        overlay.style.display = 'block';
        document.body.style.overflow = 'hidden';
      });
    }
    function closeCart() {
      drawer.classList.remove('open');
      overlay.style.display = 'none';
      document.body.style.overflow = '';
    }

    if (closeBtn) closeBtn.addEventListener('click', closeCart);
    if (overlay)  overlay.addEventListener('click', closeCart);

    document.addEventListener('click', function(e) {
      if (e.target.closest('.lg-header-cart')) openCart();
    });

    // Expose for product page
    window.lgOpenCart = openCart;
    window.lgRenderCart = renderCart;
  })();
  </script>
</body>
</html>
