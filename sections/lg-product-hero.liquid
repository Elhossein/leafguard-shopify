<!-- ══ FAQ ══ -->
<section class="lg-faq">
  <div class="lg-faq-inner">
    <p class="lg-eyebrow" style="text-align:center">GOT QUESTIONS?</p>
    <h2 class="lg-section-title" style="text-align:center">Frequently Asked Questions</h2>
    <div class="lg-faq-list">

      <details class="lg-faq-item">
