.lg-footer { background: #0a1f0a; color: rgba(255,255,255,0.75); padding: 56px 24px 24px; }
.lg-footer-inner { max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 40px; margin-bottom: 40px; }
@media (max-width: 640px) { .lg-footer-inner { grid-template-columns: 1fr; gap: 32px; } }
.lg-footer-logo { height: 48px; width: auto; margin-bottom: 12px; filter: brightness(0) invert(1) opacity(0.9); }
.lg-footer-brand p { font-size: 0.85rem; color: rgba(255,255,255,0.5); }
.lg-footer-links { display: flex; flex-direction: column; gap: 0; }
.lg-footer-links strong { font-size: 0.78rem; font-weight: 700; color: #7ee887; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 12px; }
.lg-footer-links a { font-size: 0.85rem; color: rgba(255,255,255,0.6); padding: 4px 0; transition: color 0.15s; }
.lg-footer-links a:hover { color: #7ee887; }
.lg-footer-bottom { max-width: 1080px; margin: 0 auto; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
.lg-footer-bottom p { font-size: 0.78rem; color: rgba(255,255,255,0.4); }
.lg-footer-badges { display: flex; gap: 16px; font-size: 0.75rem; color: rgba(255,255,255,0.5); }

/* ── Sticky buy bar ── */
.lg-sticky-bar {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 500;
  background: #fff; border-top: 1px solid #e0e0e0;
  padding: 12px 20px; display: flex; align-items: center; gap: 16px;
  box-shadow: 0 -4px 16px rgba(0,0,0,0.1);
  transform: translateY(100%); transition: transform 0.3s ease;
}
.lg-sticky-info { flex: 1; }
.lg-sticky-info strong { font-size: 0.85rem; color: #1a1a1a; display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px; }
.lg-sticky-info span { font-size: 1rem; font-weight: 800; color: #0d2e0d; }
.lg-sticky-cta {
  background: linear-gradient(135deg, #0d2e0d, #1a5c1a);
  color: #fff; border: none; border-radius: 10px;
  padding: 12px 24px; font-size: 0.9rem; font-weight: 800;
  cursor: pointer; white-space: nowrap; flex-shrink: 0;
}
.lg-sticky-cta:hover { background: #1a4a1a; }
@media (min-width: 780px) { .lg-sticky-bar { display: none; } }

/* ── Utilities ── */
.lg-vh { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }

/* ── Video section ── */
.lg-video-section { padding: 72px 20px; background: #0a1f0a; }
.lg-video-section .lg-eyebrow { color: #7ee887; }
.lg-video-section .lg-section-title { color: #fff; margin-bottom: 32px; }
.lg-video-inner { max-width: 480px; margin: 0 auto; }
.lg-video-wrap {
  position: relative; border-radius: 20px; overflow: hidden;
  box-shadow: 0 8px 48px rgba(0,0,0,0.5);
  background: #000;
  display: flex; justify-content: center;
}
.lg-video-wrap video {
  display: block; width: 100%; height: auto;
  max-height: 80vh; border: none; object-fit: contain;
}
.lg-video-wrap iframe {
  display: block; width: 100%;
  aspect-ratio: 16/9; border: none;
}
</style>

