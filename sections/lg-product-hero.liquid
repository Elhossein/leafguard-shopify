{%- assign lg = product -%}
{%- assign first_variant = lg.selected_or_first_available_variant -%}

{%- assign lg_asset_imgs = 'lg-main.jpg,lg-lifestyle-1.jpg,lg-lifestyle-2.jpg,lg-lifestyle-3.jpg,lg-lifestyle-4.jpg,lg-lifestyle-5.jpg,lg-lifestyle-6.jpg,lg-lifestyle-7.jpg,lg-lifestyle-8.jpg,lg-lifestyle-9.jpg' | split: ',' -%}

<!-- ══ ANNOUNCEMENT BAR ══ -->
<div class="lg-announce" aria-hidden="true">
  <div class="lg-announce-track">
    {%- for i in (1..12) -%}
      <span>🌿 FREE SHIPPING ON ALL ORDERS</span>
      <span class="lg-announce-sep">★</span>
      <span>90-DAY RETURNS</span>
      <span class="lg-announce-sep">★</span>
      <span>TRUSTED BY 10,000+ GARDENERS</span>
      <span class="lg-announce-sep">★</span>
    {%- endfor -%}
  </div>
</div>

<!-- ══ PRODUCT HERO ══ -->
<section class="lg-hero">
  <div class="lg-hero-layout">

    <!-- LEFT: Gallery -->
    <div class="lg-gallery">
      <div class="lg-gallery-main" id="lg-gallery-main">
        {%- if lg.images.size > 0 -%}
          <img id="lg-main-img" src="{{ lg.featured_image | image_url: width: 900 }}" alt="{{ lg.title }}" class="lg-main-img" />
        {%- else -%}
          <img id="lg-main-img" src="{{ 'lg-main.jpg' | asset_url }}" alt="{{ lg.title }}" class="lg-main-img" />
        {%- endif -%}
        <!-- Zoom hint -->
        <div class="lg-zoom-badge">🔍 Tap to zoom</div>
      </div>
      <div class="lg-gallery-thumbs" id="lg-gallery-thumbs">
        {%- if lg.images.size > 0 -%}
          {%- for img in lg.images -%}
            <button type="button" class="lg-thumb{% if forloop.first %} lg-thumb--active{% endif %}"
              data-src="{{ img | image_url: width: 900 }}" aria-label="View image {{ forloop.index }}">
              <img src="{{ img | image_url: width: 120 }}" alt="{{ lg.title }}" loading="lazy" />
            </button>
          {%- endfor -%}
        {%- else -%}
          {%- for img_name in lg_asset_imgs -%}
            <button type="button" class="lg-thumb{% if forloop.first %} lg-thumb--active{% endif %}"
              data-src="{{ img_name | asset_url }}" aria-label="View image {{ forloop.index }}">
              <img src="{{ img_name | asset_url }}" alt="View {{ forloop.index }}" loading="lazy" />
            </button>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    <!-- RIGHT: Form -->
    <div class="lg-form">

      <!-- Sold badge -->
      <div class="lg-social-proof">
        <span class="lg-social-dot"></span>
        <span>🔥 <strong>48</strong> sold in the last 24 hours</span>
      </div>

      <!-- Stars -->
      <div class="lg-stars-row">
        <span class="lg-stars">★★★★★</span>
        <span class="lg-review-count">4.5 · 2,917 verified reviews</span>
      </div>

      <!-- Title -->
      <h1 class="lg-title">{{ lg.title }}</h1>

      <!-- Short desc -->
      <p class="lg-tagline">The last leaf tool you'll ever need. Clear your yard <em>10× faster</em> — no bending, no raking, no mess.</p>

      <!-- Price -->
      <div class="lg-price-row">
        <span class="lg-price" id="lg-price">{{ first_variant.price | money }}</span>
        <s class="lg-compare" id="lg-compare"{% unless first_variant.compare_at_price > first_variant.price %} style="display:none"{% endunless %}>
          {{- first_variant.compare_at_price | money -}}
        </s>
        {%- if first_variant.compare_at_price > first_variant.price -%}
          {%- assign save_pct = first_variant.compare_at_price | minus: first_variant.price | times: 100 | divided_by: first_variant.compare_at_price -%}
          <span class="lg-save-badge" id="lg-save-badge">SAVE {{ save_pct }}%</span>
        {%- else -%}
          <span class="lg-save-badge" id="lg-save-badge" style="display:none"></span>
        {%- endif -%}
        <span class="lg-per-unit" id="lg-per-unit"></span>
      </div>

      <!-- Variant data -->
      <script id="lg-variant-data" type="application/json">
        [
          {%- for v in lg.variants -%}
            {
              "id":               {{ v.id }},
              "option1":          {{ v.option1 | json }},
              "price":            {{ v.price }},
              "compare_at_price": {{ v.compare_at_price | default: 0 }},
              "available":        {{ v.available }}
            }{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        ]
      </script>

      <!-- Buy More Save More -->
      <div class="lg-bmsm-head">
        <span class="lg-bmsm-line"></span>
        <span class="lg-bmsm-text">Buy More &amp; Save</span>
        <span class="lg-bmsm-line"></span>
      </div>

      <div class="lg-bundle-picker">

        <!-- 1 Pair -->
        <div class="lg-bundle-wrap">
          <label class="lg-bundle-row lg-bundle-row--active">
            <input type="radio" name="lg-bundle" class="lg-bundle-radio lg-vh" value="1" checked data-qty="1" data-discount="0" />
            <div class="lg-bundle-top">
              <div class="lg-radio-dot"></div>
              <div class="lg-bundle-info">
                <span class="lg-bundle-name">1 Pair</span>
                <span class="lg-bundle-sub">Regular price</span>
              </div>
              <div class="lg-bundle-pricing">
                <span class="lg-bundle-total" data-qty="1" data-discount="0"></span>
              </div>
            </div>
          </label>
        </div>

        <!-- 2 Pairs — Save 10% -->
        <div class="lg-bundle-wrap">
          <label class="lg-bundle-row">
            <input type="radio" name="lg-bundle" class="lg-bundle-radio lg-vh" value="2" data-qty="2" data-discount="10" />
            <div class="lg-bundle-top">
              <div class="lg-radio-dot"></div>
              <div class="lg-bundle-info">
                <span class="lg-bundle-name">2 Pairs</span>
                <span class="lg-bundle-sub lg-bundle-sub--deal">💰 Save 10% — Great for a couple</span>
              </div>
              <div class="lg-bundle-pricing">
                <span class="lg-bundle-total" data-qty="2" data-discount="10"></span>
                <s class="lg-bundle-was" data-qty="2"></s>
              </div>
            </div>
          </label>
        </div>

        <!-- 4 Pairs — Save 25% — Most Popular -->
        <div class="lg-bundle-wrap lg-bundle-wrap--popular">
          <div class="lg-popular-tag">🌟 MOST POPULAR</div>
          <label class="lg-bundle-row">
            <input type="radio" name="lg-bundle" class="lg-bundle-radio lg-vh" value="4" data-qty="4" data-discount="25" />
            <div class="lg-bundle-top">
              <div class="lg-radio-dot"></div>
              <div class="lg-bundle-info">
                <span class="lg-bundle-name">4 Pairs</span>
                <span class="lg-bundle-sub lg-bundle-sub--deal">🔥 Save 25% — Perfect for the whole family</span>
              </div>
              <div class="lg-bundle-pricing">
                <span class="lg-bundle-total" data-qty="4" data-discount="25"></span>
                <s class="lg-bundle-was" data-qty="4"></s>
              </div>
            </div>
          </label>
        </div>

      </div><!-- /.lg-bundle-picker -->

      <!-- CTA — top position -->
      <button type="button" class="lg-cta-btn" id="lg-cta-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        Buy Now — <span id="lg-cta-price"></span>
      </button>

      <p class="lg-shipping-note">🚚 Free shipping · Delivers to all US states in <strong>5–10 business days</strong></p>

      <!-- Urgency timer -->
      <div class="lg-urgency">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span>Deal ends in <strong id="lg-timer">23:47:12</strong> — only <strong>7 left</strong> at this price</span>
      </div>

      <!-- Feature bullets — below CTA -->
      <ul class="lg-bullets">
        <li><span class="lg-bullet-icon">🍂</span> Clears leaves <strong>10× faster</strong> than a traditional rake</li>
        <li><span class="lg-bullet-icon">💪</span> V2.0 — thicker, reinforced plastic handles heavier loads</li>
        <li><span class="lg-bullet-icon">🦺</span> Ergonomic comfort grip — zero hand fatigue</li>
        <li><span class="lg-bullet-icon">📦</span> Stack &amp; store — wall peg hole for easy shed hanging</li>
        <li><span class="lg-bullet-icon">✅</span> Fits all bag sizes — paper lawn bags, garbage bags</li>
      </ul>

      <!-- Trust row — below bullets -->
      <div class="lg-trust-row">
        <div class="lg-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          <span>Free Shipping</span>
        </div>
        <div class="lg-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <span>30-Day Guarantee</span>
        </div>
        <div class="lg-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          <span>Secure Checkout</span>
        </div>
      </div>

      <!-- Collapsibles -->
      <div class="lg-collapsibles">

        <details class="lg-detail">
          <summary class="lg-detail-summary">
            <span class="lg-detail-icon">📦</span>
            What's in the box
            <svg class="lg-detail-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="lg-detail-body">
            <p>1 × Pair of LeafGuard Leaf Scoops V2.0 (2 pieces total) · Ergonomic comfort-grip handles · Reinforced heavy-duty plastic construction · Wall peg storage hole built-in.</p>
          </div>
        </details>

        <details class="lg-detail">
          <summary class="lg-detail-summary">
            <span class="lg-detail-icon">⚙️</span>
            How to use
            <svg class="lg-detail-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="lg-detail-body">
            <p>Slip your hands into the ergonomic handles and walk across your lawn. Scoop leaves, grass clippings, twigs, and debris directly into a bag or pile in seconds. Works on wet or dry material. When done, stack the pair together and hang on a wall peg.</p>
          </div>
        </details>

        <details class="lg-detail">
          <summary class="lg-detail-summary">
            <span class="lg-detail-icon">🛡️</span>
            30-Day Guarantee
            <svg class="lg-detail-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="lg-detail-body">
            <p>Not happy for any reason? We'll refund you in full within 30 days — no questions, no hassle. Just reach out to our support team.</p>
          </div>
        </details>

        <details class="lg-detail">
          <summary class="lg-detail-summary">
            <span class="lg-detail-icon">🚚</span>
            Shipping &amp; Delivery
            <svg class="lg-detail-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="lg-detail-body">
            <p>Free standard shipping on all US orders. Arrives in 5–10 business days. Orders placed before 2 PM EST are processed same day. Tracking provided by email.</p>
          </div>
        </details>

      </div><!-- /.lg-collapsibles -->

    </div><!-- /.lg-form -->
  </div><!-- /.lg-hero-layout -->
</section>

<!-- ══ PRODUCT VIDEO ══ -->
{%- assign lg_video = nil -%}
{%- for media in lg.media -%}
  {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
    {%- assign lg_video = media -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}
{%- if lg_video -%}
<section class="lg-video-section">
  <div class="lg-video-inner">
    <p class="lg-eyebrow" style="text-align:center">SEE IT IN ACTION</p>
    <h2 class="lg-section-title" style="text-align:center">Watch How It Works</h2>
    <div class="lg-video-wrap">
      {%- if lg_video.media_type == 'external_video' -%}
        {%- if lg_video.host == 'youtube' -%}
          <iframe src="https://www.youtube.com/embed/{{ lg_video.external_id }}?autoplay=0&rel=0"
            title="Product video" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen loading="lazy"></iframe>
        {%- elsif lg_video.host == 'vimeo' -%}
          <iframe src="https://player.vimeo.com/video/{{ lg_video.external_id }}"
            title="Product video" frameborder="0" allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen loading="lazy"></iframe>
        {%- endif -%}
      {%- else -%}
        <video controls autoplay muted loop playsinline preload="auto" poster="{{ lg_video.preview_image | image_url: width: 1200 }}" style="background:#000">
          {%- for source in lg_video.sources -%}
            <source src="{{ source.url }}" type="{{ source.mime_type }}" />
          {%- endfor -%}
        </video>
      {%- endif -%}
    </div>
  </div>
</section>
{%- endif -%}

<!-- ══ SOCIAL PROOF STRIP ══ -->
<section class="lg-proof-strip">
  <div class="lg-proof-track">
    {%- for i in (1..8) -%}
      <span>"Finally — a leaf tool that actually works!" — <strong>Mike T.</strong></span>
      <span class="lg-proof-sep">★★★★★</span>
      <span>"Cleared my whole yard in 20 min. Incredible." — <strong>Sarah K.</strong></span>
      <span class="lg-proof-sep">★★★★★</span>
      <span>"Bought 3 pairs — one for every family member!" — <strong>James R.</strong></span>
      <span class="lg-proof-sep">★★★★★</span>
