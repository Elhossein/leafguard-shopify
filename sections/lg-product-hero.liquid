  </div>
</section>

<!-- ══ HOW IT WORKS ══ -->
<section class="lg-how">
  <div class="lg-section-inner">
    <p class="lg-eyebrow">SIMPLE STEPS</p>
    <h2 class="lg-section-title">Clear Your Yard in 3 Easy Steps</h2>
