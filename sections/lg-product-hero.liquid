<!-- ══ STICKY BUY BAR (mobile) ══ -->
<div class="lg-sticky-bar" id="lg-sticky-bar">
  <div class="lg-sticky-info">
    <strong>{{ lg.title | truncate: 40 }}</strong>
    <span id="lg-sticky-price"></span>
  </div>
  <button class="lg-sticky-cta" id="lg-sticky-btn">Buy Now</button>
</div>

<script>
(function () {
  var variants  = JSON.parse(document.getElementById('lg-variant-data').textContent);
  var mainImg   = document.getElementById('lg-main-img');
  var ctaBtn    = document.getElementById('lg-cta-btn');
  var stickyBtn = document.getElementById('lg-sticky-btn');
  var ctaPrice  = document.getElementById('lg-cta-price');
  var priceEl   = document.getElementById('lg-price');
  var compareEl = document.getElementById('lg-compare');
  var saveBadge = document.getElementById('lg-save-badge');
  var perUnit   = document.getElementById('lg-per-unit');
  var stickyPrice = document.getElementById('lg-sticky-price');
  var stickyBar = document.getElementById('lg-sticky-bar');

  // Track selected bundle in JS variables — don't rely on DOM :checked state
  var selectedQty  = 1;
  var selectedDisc = 0;

  function fmt(cents) { return '$' + (cents / 100).toFixed(2); }
  function getActiveQty()  { return selectedQty; }
  function getActiveDisc() { return selectedDisc; }

  function updateBundlePrices() {
    var base = variants[0]; if (!base) return;
    document.querySelectorAll('.lg-bundle-total[data-qty]').forEach(function (el) {
      var qty  = parseInt(el.dataset.qty, 10);
      var disc = parseInt(el.dataset.discount || '0', 10);
      el.textContent = fmt(Math.round(base.price * qty * (1 - disc / 100)));
    });
    document.querySelectorAll('.lg-bundle-was[data-qty]').forEach(function (el) {
      el.textContent = fmt(base.price * parseInt(el.dataset.qty, 10));
    });
  }

  function updateUI() {
    var qty  = getActiveQty();
    var disc = getActiveDisc();
    var base = variants[0]; if (!base) return;
    var total = Math.round(base.price * qty * (1 - disc / 100));
    var orig  = base.price * qty;
    if (ctaPrice)   ctaPrice.textContent  = fmt(total);
    if (priceEl)    priceEl.textContent   = fmt(total);
    if (stickyPrice) stickyPrice.textContent = fmt(total);
    if (compareEl) {
      compareEl.textContent = disc > 0 ? fmt(orig) : (base.compare_at_price > 0 ? fmt(base.compare_at_price) : '');
      compareEl.style.display = (disc > 0 || base.compare_at_price > base.price) ? 'inline' : 'none';
    }
    if (saveBadge) {
      if (disc > 0) {
        saveBadge.textContent = 'SAVE ' + disc + '%';
        saveBadge.style.display = 'inline-flex';
      } else if (base.compare_at_price > base.price) {
        var pct = Math.round((base.compare_at_price - base.price) * 100 / base.compare_at_price);
        saveBadge.textContent = 'SAVE ' + pct + '%';
        saveBadge.style.display = 'inline-flex';
      } else {
        saveBadge.style.display = 'none';
      }
    }
    if (perUnit && qty > 1) {
      perUnit.textContent = '(' + fmt(Math.round(total / qty)) + '/pair)';
      perUnit.style.display = 'inline';
    } else if (perUnit) {
      perUnit.style.display = 'none';
    }
  }

  function activateBundle(qty, disc, row) {
    selectedQty  = qty;
    selectedDisc = disc;
    document.querySelectorAll('.lg-bundle-row').forEach(function (r) { r.classList.remove('lg-bundle-row--active'); });
    row.classList.add('lg-bundle-row--active');
    updateUI();
  }

  document.querySelectorAll('.lg-bundle-row').forEach(function (row) {
    row.addEventListener('click', function () {
      var radio = row.querySelector('.lg-bundle-radio');
      if (radio) {
        var qty  = parseInt(radio.dataset.qty, 10) || 1;
        var disc = parseInt(radio.dataset.discount || '0', 10);
        activateBundle(qty, disc, row);
      }
    });
  });

  // Thumbnails
  document.querySelectorAll('.lg-thumb').forEach(function (thumb) {
    thumb.addEventListener('click', function () {
      if (mainImg) mainImg.src = thumb.dataset.src;
      document.querySelectorAll('.lg-thumb').forEach(function (t) { t.classList.remove('lg-thumb--active'); });
      thumb.classList.add('lg-thumb--active');
    });
  });

  // Buy Now
  async function buyNow() {
    var origHTML = ctaBtn ? ctaBtn.innerHTML : '';
    if (ctaBtn) { ctaBtn.disabled = true; ctaBtn.textContent = 'Adding…'; }
    if (stickyBtn) { stickyBtn.disabled = true; stickyBtn.textContent = 'Adding…'; }
    try {
      var v = variants[0];
      if (!v) { alert('Product variant not found. Please refresh.'); throw new Error('no variant'); }
      var qty = getActiveQty();
      await fetch('/cart/clear.js', { method: 'POST' });
      var res = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ items: [{ id: v.id, quantity: qty }] })
      });
      if (!res.ok) { var e = await res.json().catch(function(){return{};}); throw new Error(e.description || 'Cart error ' + res.status); }
      window.location.replace('/checkout');
    } catch (err) {
      if (err.message !== 'no variant') alert('Could not add to cart: ' + err.message);
      if (ctaBtn) { ctaBtn.disabled = false; ctaBtn.innerHTML = origHTML; }
      if (stickyBtn) { stickyBtn.disabled = false; stickyBtn.textContent = 'Buy Now'; }
    }
  }

  if (ctaBtn)    ctaBtn.addEventListener('click', buyNow);
  if (stickyBtn) stickyBtn.addEventListener('click', buyNow);

  // Sticky bar show on scroll
  var heroForm = document.querySelector('.lg-form');
  if (heroForm && stickyBar) {
    var obs = new IntersectionObserver(function(entries) {
      stickyBar.style.transform = entries[0].isIntersecting ? 'translateY(100%)' : 'translateY(0)';
    }, { threshold: 0.1 });
    obs.observe(heroForm);
  }

  // Countdown timer
  var timerEl = document.getElementById('lg-timer');
  if (timerEl) {
    var secs = 23 * 3600 + 47 * 60 + 12;
    setInterval(function() {
      secs = Math.max(0, secs - 1);
      var h = Math.floor(secs / 3600);
      var m = Math.floor((secs % 3600) / 60);
      var s = secs % 60;
      timerEl.textContent = [h, m, s].map(function(n){ return n.toString().padStart(2,'0'); }).join(':');
    }, 1000);
  }

  updateBundlePrices();
  updateUI();
})();
</script>

